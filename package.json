{
  "name": "mtb-galaxy",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "packages/contracts"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --app-dir apps/api --reload --port 8000",
    "dev:web": "npm run dev --workspace @mtb/web",
    "build:web": "npm run build --workspace @mtb/web",
    "preview": "node scripts/serve-web.mjs",
    "start:web": "node scripts/serve-web.mjs",
    "test:api": ".\\.venv\\Scripts\\python.exe -m pytest apps/api/tests",
    "test:web": "npm run test --workspace @mtb/web",
    "contracts:generate": ".\\.venv\\Scripts\\python.exe apps/api/scripts/export_openapi.py && openapi-typescript apps/api/openapi.json -o packages/contracts/src/generated/api.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "openapi-typescript": "^7.7.0"
  }
}
